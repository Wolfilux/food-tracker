# Copy to .env for local development.
# Never commit real secrets.

# DATABASE_URL=
# API_SECRET=

# Garmin Connect credentials are configured in the Web UI and stored encrypted server-side.

# Weekly email SMTP settings. The target recipient is configured in the Web UI.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Food Tracker <food-tracker@example.com>

# Optional calendar context for weekly AI analysis. Use a dedicated CalDAV account/app password.
# Only busy blocks are sent to the AI prompt, no event titles or descriptions.
# CALDAV_URL=https://mail.example.com/SOGo/dav/user@example.com/Calendar/personal/
# CALDAV_USER=user@example.com
# CALDAV_PASS=
# CALENDAR_LOOKAHEAD_DAYS=14
